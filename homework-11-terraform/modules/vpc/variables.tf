# =============================================================================
# VARIABLES.TF — Оголошення вхідних параметрів модуля
# =============================================================================
#
# Навіщо цей файл?
# ----------------
# Коли хтось буде використовувати наш модуль VPC, він передасть параметри:
#
#   module "vpc" {
#     source   = "./modules/vpc"
#     vpc_cidr = "10.0.0.0/16"    <-- ось ці значення
#     vpc_name = "my-vpc"          <-- описані тут
#   }
#
# Цей файл каже Terraform: "Я очікую такі параметри"
# =============================================================================


# -----------------------------------------------------------------------------
# Параметр: vpc_cidr
# -----------------------------------------------------------------------------
# Це діапазон IP-адрес для нашої мережі.
# Приклад: "10.0.0.0/16" дає нам 65,536 IP-адрес.

variable "vpc_cidr" {
  # description — опис для документації (що це і навіщо)
  description = "CIDR блок для VPC (діапазон IP-адрес)"

  # type — який тип даних очікуємо (string = текст)
  type = string

  # default — значення за замовчуванням, якщо не передали
  default = "10.0.0.0/16"
}


# -----------------------------------------------------------------------------
# Параметр: vpc_name
# -----------------------------------------------------------------------------
# Назва VPC — буде видно в AWS Console для зручності.

variable "vpc_name" {
  description = "Назва VPC для тегування"
  type        = string
  default     = "main-vpc"
}


# -----------------------------------------------------------------------------
# Параметр: tags
# -----------------------------------------------------------------------------
# Теги — це мітки "ключ = значення" для організації ресурсів.
# Приклад: { Environment = "dev", Project = "homework" }
# В AWS Console можна фільтрувати ресурси по тегах.

variable "tags" {
  description = "Додаткові теги для ресурсів"

  # map(string) — словник, де ключі і значення це текст
  type = map(string)

  # Порожній словник за замовчуванням
  default = {}
}