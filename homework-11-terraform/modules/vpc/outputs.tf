# =============================================================================
# OUTPUTS.TF — Що модуль повертає назовні
# =============================================================================
#
# Навіщо цей файл?
# ----------------
# Коли ми створили VPC та Internet Gateway, AWS присвоїв їм унікальні ID.
# Ці ID потрібні іншим модулям!
#
# Наприклад, модуль subnets повинен знати vpc_id, щоб створити підмережі
# всередині правильного VPC.
#
# Без outputs інші модулі не зможуть отримати ці значення.
#
# Як використовувати:
#   module.vpc.vpc_id              — отримати ID VPC
#   module.vpc.internet_gateway_id — отримати ID Internet Gateway
# =============================================================================


# -----------------------------------------------------------------------------
# Output: vpc_id
# -----------------------------------------------------------------------------
# ID нашого VPC — потрібен для створення підмереж, серверів, тощо.
# Все, що живе в VPC, повинно знати його ID.

output "vpc_id" {
  # description — опис для документації
  description = "ID створеного VPC"

  # value — яке значення повертаємо
  # aws_vpc.main.id — беремо атрибут id з ресурсу aws_vpc.main
  value = aws_vpc.main.id
}


# -----------------------------------------------------------------------------
# Output: internet_gateway_id
# -----------------------------------------------------------------------------
# ID Internet Gateway — потрібен для налаштування Route Table.
# Route Table використовує цей ID, щоб сказати "трафік йде через цей gateway".

output "internet_gateway_id" {
  description = "ID Internet Gateway"
  value       = aws_internet_gateway.main.id
}


# -----------------------------------------------------------------------------
# Output: vpc_cidr
# -----------------------------------------------------------------------------
# CIDR блок VPC — може знадобитися для Security Groups або документації.

output "vpc_cidr" {
  description = "CIDR блок VPC"
  value       = aws_vpc.main.cidr_block
}
