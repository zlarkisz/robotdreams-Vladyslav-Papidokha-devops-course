# =============================================================================
# MAIN.TF — Опис ресурсів, які створюємо
# =============================================================================
#
# Навіщо цей файл?
# ----------------
# Тут ми описуємо ЩО створити в AWS.
# Terraform прочитає цей файл і створить реальні ресурси.
#
# Синтаксис:
#   resource "тип_ресурсу" "локальне_імʼя" {
#     параметр = значення
#   }
#
# - тип_ресурсу: що створюємо (aws_vpc, aws_instance, aws_s3_bucket...)
# - локальне_імʼя: як називаємо в коді (для посилань)
# =============================================================================


# -----------------------------------------------------------------------------
# Ресурс: VPC (Virtual Private Cloud)
# -----------------------------------------------------------------------------
# Що це?
#   VPC — ізольована мережа в AWS. Твій власний "дата-центр" в хмарі.
#   Всі ресурси (сервери, бази даних) живуть всередині VPC.
#
# Навіщо?
#   Без VPC ресурси були б у спільній мережі з іншими клієнтами AWS.
#   VPC дає ізоляцію та контроль над мережею.

resource "aws_vpc" "main" {
  # cidr_block — діапазон IP-адрес для цієї мережі
  # var.vpc_cidr — беремо значення з variables.tf
  cidr_block = var.vpc_cidr

  # enable_dns_hostnames — чи давати серверам DNS імена
  # Якщо true: сервер отримає ім'я типу ip-10-0-1-5.ec2.internal
  # Якщо false: тільки IP-адреса
  enable_dns_hostnames = true

  # enable_dns_support — чи працює DNS всередині VPC
  # Потрібно для того, щоб сервери могли знаходити один одного по імені
  enable_dns_support = true

  # tags — мітки для ресурсу (видно в AWS Console)
  # merge() — функція, що об'єднує два словники в один
  # { Name = var.vpc_name } — обов'язковий тег Name
  # var.tags — додаткові теги, які передали в модуль
  tags = merge(
    { Name = var.vpc_name },
    var.tags
  )
}


# -----------------------------------------------------------------------------
# Ресурс: Internet Gateway
# -----------------------------------------------------------------------------
# Що це?
#   Internet Gateway — "двері" між VPC та інтернетом.
#   Без нього сервери в VPC повністю ізольовані від світу.
#
# Навіщо?
#   Щоб сервери могли:
#   - Завантажувати пакети з інтернету (apt install, npm install)
#   - Бути доступними ззовні (веб-сервер)
#
# Важливо:
#   Сам по собі Internet Gateway не дає доступу!
#   Потрібна ще Route Table, яка скаже "трафік в інтернет йде через IGW".
#   Це налаштуємо в модулі subnets.

resource "aws_internet_gateway" "main" {
  # vpc_id — до якого VPC прикріпити цей Internet Gateway
  # aws_vpc.main.id — посилання на ID нашого VPC (створеного вище)
  #
  # Як читати: aws_vpc.main.id
  #   aws_vpc — тип ресурсу
  #   main — локальне ім'я (те, що ми написали в лапках)
  #   id — атрибут ресурсу (AWS присвоює після створення)
  vpc_id = aws_vpc.main.id

  # tags — мітки для ресурсу
  # "${var.vpc_name}-igw" — склеювання рядків (інтерполяція)
  # Якщо vpc_name = "my-vpc", результат буде "my-vpc-igw"
  tags = merge(
    { Name = "${var.vpc_name}-igw" },
    var.tags
  )
}
