# =============================================================================
# SUBNETS MODULE — OUTPUTS (що повертаємо)
# =============================================================================
#
# Ці значення потрібні іншим модулям:
# - Модуль EC2 повинен знати subnet_id, щоб запустити сервер у правильній підмережі
# =============================================================================


# -----------------------------------------------------------------------------
# Output: public_subnet_id
# -----------------------------------------------------------------------------
# ID публічної підмережі — для створення серверів з доступом до інтернету

output "public_subnet_id" {
  description = "ID публічної підмережі"
  value       = aws_subnet.public.id
}


# -----------------------------------------------------------------------------
# Output: private_subnet_id
# -----------------------------------------------------------------------------
# ID приватної підмережі — для створення ізольованих серверів

output "private_subnet_id" {
  description = "ID приватної підмережі"
  value       = aws_subnet.private.id
}


# -----------------------------------------------------------------------------
# Output: public_route_table_id
# -----------------------------------------------------------------------------
# ID публічної Route Table — може знадобитися для додаткових налаштувань

output "public_route_table_id" {
  description = "ID публічної Route Table"
  value       = aws_route_table.public.id
}


# -----------------------------------------------------------------------------
# Output: private_route_table_id
# -----------------------------------------------------------------------------
# ID приватної Route Table

output "private_route_table_id" {
  description = "ID приватної Route Table"
  value       = aws_route_table.private.id
}