# =============================================================================
# SUBNETS MODULE — VARIABLES (вхідні параметри)
# =============================================================================
#
# Цей модуль створює дві підмережі:
#   1. Public subnet — сервери мають доступ до інтернету
#   2. Private subnet — сервери ізольовані від інтернету
# =============================================================================


# -----------------------------------------------------------------------------
# Параметр: vpc_id
# -----------------------------------------------------------------------------
# ID VPC, в якому створюємо підмережі.
# Отримаємо з модуля VPC: module.vpc.vpc_id

variable "vpc_id" {
  description = "ID VPC, в якому створювати підмережі"
  type        = string
  # Немає default — цей параметр ОБОВ'ЯЗКОВИЙ
  # Terraform видасть помилку, якщо не передати
}


# -----------------------------------------------------------------------------
# Параметр: internet_gateway_id
# -----------------------------------------------------------------------------
# ID Internet Gateway — потрібен для Route Table публічної підмережі.
# Щоб трафік з публічної підмережі йшов в інтернет.

variable "internet_gateway_id" {
  description = "ID Internet Gateway для публічної підмережі"
  type        = string
}


# -----------------------------------------------------------------------------
# Параметр: public_subnet_cidr
# -----------------------------------------------------------------------------
# Діапазон IP-адрес для публічної підмережі.
# Повинен бути ВСЕРЕДИНІ VPC CIDR!
# Якщо VPC = 10.0.0.0/16, то підмережа може бути 10.0.1.0/24

variable "public_subnet_cidr" {
  description = "CIDR блок для публічної підмережі"
  type        = string
  default     = "10.0.1.0/24"  # 256 адрес: 10.0.1.0 — 10.0.1.255
}


# -----------------------------------------------------------------------------
# Параметр: private_subnet_cidr
# -----------------------------------------------------------------------------
# Діапазон IP-адрес для приватної підмережі.

variable "private_subnet_cidr" {
  description = "CIDR блок для приватної підмережі"
  type        = string
  default     = "10.0.2.0/24"  # 256 адрес: 10.0.2.0 — 10.0.2.255
}


# -----------------------------------------------------------------------------
# Параметр: availability_zone
# -----------------------------------------------------------------------------
# Availability Zone (AZ) — фізичний дата-центр в регіоні.
# Регіон eu-central-1 (Frankfurt) має кілька AZ:
#   - eu-central-1a
#   - eu-central-1b
#   - eu-central-1c
# Для надійності в продакшені роблять підмережі в різних AZ.

variable "availability_zone" {
  description = "Availability Zone для підмереж"
  type        = string
  default     = "eu-central-1a"
}


# -----------------------------------------------------------------------------
# Параметр: project_name
# -----------------------------------------------------------------------------
# Назва проекту — для тегів і назв ресурсів.

variable "project_name" {
  description = "Назва проекту для тегування"
  type        = string
  default     = "terraform-hw"
}


# -----------------------------------------------------------------------------
# Параметр: tags
# -----------------------------------------------------------------------------
# Додаткові теги.

variable "tags" {
  description = "Додаткові теги для ресурсів"
  type        = map(string)
  default     = {}
}