# =============================================================================
# SUBNETS MODULE — MAIN (створення ресурсів)
# =============================================================================
#
# КЛЮЧОВА КОНЦЕПЦІЯ: Публічна vs Приватна підмережа
# =================================================
#
# Сама підмережа не знає, чи вона публічна чи приватна!
# Різниця — в Route Table (таблиці маршрутизації):
#
#   Публічна підмережа:
#     Route Table має запис: 0.0.0.0/0 → Internet Gateway
#     Це означає: "весь трафік в інтернет йде через IGW"
#
#   Приватна підмережа:
#     Route Table НЕ має маршруту в інтернет
#     Сервери не можуть вийти в інтернет (і ззовні до них не дістатись)
#
# =============================================================================


# -----------------------------------------------------------------------------
# Ресурс: Публічна підмережа (Public Subnet)
# -----------------------------------------------------------------------------
# Тут будуть жити сервери, доступні з інтернету (веб-сервери, load balancer).

resource "aws_subnet" "public" {
  # В якому VPC створюємо підмережу
  vpc_id = var.vpc_id

  # Діапазон IP-адрес для цієї підмережі
  # Повинен бути частиною VPC CIDR
  cidr_block = var.public_subnet_cidr

  # В якому дата-центрі (Availability Zone)
  availability_zone = var.availability_zone

  # ВАЖЛИВО: автоматично давати публічний IP серверам в цій підмережі
  # Якщо true — EC2 одразу отримає публічний IP при запуску
  # Якщо false — потрібно вручну призначати Elastic IP
  map_public_ip_on_launch = true

  tags = merge(
    {
      Name = "${var.project_name}-public-subnet"
      Type = "Public"  # Додатковий тег для зручності
    },
    var.tags
  )
}


# -----------------------------------------------------------------------------
# Ресурс: Приватна підмережа (Private Subnet)
# -----------------------------------------------------------------------------
# Тут будуть жити сервери, які НЕ повинні бути доступні з інтернету
# (бази даних, внутрішні сервіси).

resource "aws_subnet" "private" {
  vpc_id            = var.vpc_id
  cidr_block        = var.private_subnet_cidr
  availability_zone = var.availability_zone

  # ВАЖЛИВО: НЕ давати публічний IP
  # Сервери в приватній підмережі не повинні мати публічних IP
  map_public_ip_on_launch = false

  tags = merge(
    {
      Name = "${var.project_name}-private-subnet"
      Type = "Private"
    },
    var.tags
  )
}


# -----------------------------------------------------------------------------
# Ресурс: Route Table для публічної підмережі
# -----------------------------------------------------------------------------
# Route Table — це "карта маршрутів" для мережевого трафіку.
# Вона каже: "Якщо трафік йде на адресу X — відправ його через Y"
#
# Для публічної підмережі додаємо маршрут в інтернет через Internet Gateway.

resource "aws_route_table" "public" {
  # В якому VPC
  vpc_id = var.vpc_id

  # Правило маршрутизації:
  # destination = 0.0.0.0/0 означає "весь трафік" (будь-яка адреса)
  # gateway_id = IGW означає "відправляй через Internet Gateway"
  route {
    cidr_block = "0.0.0.0/0"                # Куди: весь інтернет
    gateway_id = var.internet_gateway_id    # Через що: Internet Gateway
  }

  tags = merge(
    { Name = "${var.project_name}-public-rt" },
    var.tags
  )
}


# -----------------------------------------------------------------------------
# Ресурс: Route Table для приватної підмережі
# -----------------------------------------------------------------------------
# Приватна Route Table НЕ має маршруту в інтернет.
# Трафік залишається тільки всередині VPC.
#
# Примітка: якщо приватним серверам потрібен доступ в інтернет
# (наприклад, для оновлень), додають NAT Gateway. Але він коштує ~$32/міс,
# тому для навчання не використовуємо.

resource "aws_route_table" "private" {
  vpc_id = var.vpc_id

  # Тут НЕМАЄ route в інтернет!
  # Трафік з приватної підмережі не може вийти назовні

  tags = merge(
    { Name = "${var.project_name}-private-rt" },
    var.tags
  )
}


# -----------------------------------------------------------------------------
# Ресурс: Прив'язка Route Table до публічної підмережі
# -----------------------------------------------------------------------------
# Route Table сама по собі нічого не робить.
# Потрібно ПРИВ'ЯЗАТИ її до підмережі.
# Після цього всі сервери в підмережі будуть використовувати цю Route Table.

resource "aws_route_table_association" "public" {
  # Яку підмережу прив'язуємо
  subnet_id = aws_subnet.public.id

  # До якої Route Table
  route_table_id = aws_route_table.public.id
}


# -----------------------------------------------------------------------------
# Ресурс: Прив'язка Route Table до приватної підмережі
# -----------------------------------------------------------------------------

resource "aws_route_table_association" "private" {
  subnet_id      = aws_subnet.private.id
  route_table_id = aws_route_table.private.id
}