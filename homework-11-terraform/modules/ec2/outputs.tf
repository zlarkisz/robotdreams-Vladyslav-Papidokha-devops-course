# =============================================================================
# EC2 MODULE — OUTPUTS (що повертаємо)
# =============================================================================
#
# Ці значення потрібні для:
#   - Підключення до сервера (IP-адреса)
#   - Моніторингу (instance_id)
#   - Налаштування інших ресурсів
# =============================================================================


# -----------------------------------------------------------------------------
# Output: instance_id
# -----------------------------------------------------------------------------
# Унікальний ID інстансу в AWS (наприклад: i-0abc123def456789)
# Потрібен для моніторингу, логів, підключення інших сервісів.

output "instance_id" {
  description = "ID EC2 інстансу"
  value       = aws_instance.this.id
}


# -----------------------------------------------------------------------------
# Output: public_ip
# -----------------------------------------------------------------------------
# Публічна IP-адреса сервера (якщо є).
# По цій адресі можна підключитися з інтернету.
# Буде тільки у серверів в публічній підмережі!

output "public_ip" {
  description = "Публічна IP-адреса (якщо є)"
  value       = aws_instance.this.public_ip
}


# -----------------------------------------------------------------------------
# Output: private_ip
# -----------------------------------------------------------------------------
# Приватна IP-адреса сервера (є завжди).
# Це адреса всередині VPC (наприклад: 10.0.1.15).
# По ній сервери спілкуються один з одним всередині VPC.

output "private_ip" {
  description = "Приватна IP-адреса"
  value       = aws_instance.this.private_ip
}


# -----------------------------------------------------------------------------
# Output: security_group_id
# -----------------------------------------------------------------------------
# ID Security Group — може знадобитися для додаткових правил.

output "security_group_id" {
  description = "ID Security Group"
  value       = aws_security_group.this.id
}