# =============================================================================
# EC2 MODULE — VARIABLES (вхідні параметри)
# =============================================================================
#
# EC2 (Elastic Compute Cloud) — це віртуальні сервери в AWS.
# Цей модуль створює один EC2 інстанс + Security Group для нього.
# =============================================================================


# -----------------------------------------------------------------------------
# Параметр: instance_name
# -----------------------------------------------------------------------------
# Назва сервера — буде видно в AWS Console

variable "instance_name" {
  description = "Назва EC2 інстансу"
  type        = string
  # Немає default — обов'язковий параметр
}


# -----------------------------------------------------------------------------
# Параметр: instance_type
# -----------------------------------------------------------------------------
# Тип інстансу визначає потужність сервера (CPU, RAM).
#
# Популярні типи:
#   t2.micro  — 1 vCPU, 1 GB RAM (Free Tier!)
#   t2.small  — 1 vCPU, 2 GB RAM
#   t2.medium — 2 vCPU, 4 GB RAM
#   t3.large  — 2 vCPU, 8 GB RAM
#
# Для навчання завжди використовуй t2.micro — він безкоштовний!

variable "instance_type" {
  description = "Тип EC2 інстансу (t2.micro = Free Tier)"
  type        = string
  default     = "t2.micro"
}


# -----------------------------------------------------------------------------
# Параметр: ami_id
# -----------------------------------------------------------------------------
# AMI (Amazon Machine Image) — образ операційної системи.
# Це як ISO-файл для встановлення ОС, але вже готовий.
#
# AMI ID різні для кожного регіону!
# Ми будемо отримувати AMI динамічно в main.tf кореневого модуля.

variable "ami_id" {
  description = "ID AMI (образ операційної системи)"
  type        = string
  # Немає default — передамо з головного модуля
}


# -----------------------------------------------------------------------------
# Параметр: subnet_id
# -----------------------------------------------------------------------------
# В якій підмережі запустити сервер.
# Від цього залежить чи буде сервер публічним чи приватним.

variable "subnet_id" {
  description = "ID підмережі для EC2"
  type        = string
}


# -----------------------------------------------------------------------------
# Параметр: vpc_id
# -----------------------------------------------------------------------------
# ID VPC — потрібен для створення Security Group.

variable "vpc_id" {
  description = "ID VPC для Security Group"
  type        = string
}


# -----------------------------------------------------------------------------
# Параметр: is_public
# -----------------------------------------------------------------------------
# Чи це публічний сервер?
# Якщо true — Security Group дозволить SSH, HTTP, HTTPS з інтернету.
# Якщо false — тільки трафік зсередини VPC.

variable "is_public" {
  description = "Чи дозволити доступ з інтернету (SSH, HTTP, HTTPS)"
  type        = bool
  default     = false
}


# -----------------------------------------------------------------------------
# Параметр: tags
# -----------------------------------------------------------------------------

variable "tags" {
  description = "Додаткові теги"
  type        = map(string)
  default     = {}
}