# =============================================================================
# PROVIDERS.TF — Налаштування провайдерів
# =============================================================================
#
# Provider — це плагін, який дозволяє Terraform працювати з певним сервісом.
# AWS Provider дає нам ресурси типу aws_vpc, aws_instance, тощо.
#
# Terraform підтримує багато провайдерів:
#   - AWS, Azure, Google Cloud
#   - Kubernetes, Docker
#   - GitHub, GitLab
#   - і сотні інших
# =============================================================================


# -----------------------------------------------------------------------------
# Terraform Settings
# -----------------------------------------------------------------------------
# Вказуємо мінімальну версію Terraform та які провайдери потрібні.

terraform {
  # Мінімальна версія Terraform
  required_version = ">= 1.0.0"

  # Які провайдери використовуємо
  required_providers {
    aws = {
      source  = "hashicorp/aws"   # Звідки завантажити (Terraform Registry)
      version = "~> 5.0"          # Версія 5.x (будь-яка 5.0, 5.1, 5.2...)
    }
  }
}


# -----------------------------------------------------------------------------
# AWS Provider
# -----------------------------------------------------------------------------
# Налаштування підключення до AWS.
# Credentials беруться автоматично з ~/.aws/credentials (ми налаштували через aws configure).

provider "aws" {
  # Регіон AWS — де створювати ресурси
  region = var.aws_region

  # Теги за замовчуванням — додаються до ВСІХ ресурсів автоматично
  default_tags {
    tags = {
      Project   = "RobotDreams-Terraform-HW"
      ManagedBy = "Terraform"
    }
  }
}