# =============================================================================
# TERRAFORM IMPORT — Імпорт існуючого S3 Bucket
# =============================================================================
#
# Цей bucket був створений ВРУЧНУ через AWS Console.
# Тепер ми "підключаємо" його до Terraform, щоб керувати ним через код.
#
# Кроки:
#   1. Описуємо ресурс тут (цей файл)
#   2. Виконуємо: terraform import aws_s3_bucket.imported robotdreams-import-demo-gleb
#   3. Terraform тепер знає про цей bucket і може ним керувати
# =============================================================================


# -----------------------------------------------------------------------------
# Ресурс: S3 Bucket (імпортований)
# -----------------------------------------------------------------------------
# Цей блок описує bucket, який вже існує в AWS.
# Параметри повинні співпадати з реальним bucket!

resource "aws_s3_bucket" "imported" {
  bucket = "robotdreams-import-demo-gleb"

  tags = {
    Name        = "Imported Bucket"
    Environment = "dev"
    ManagedBy   = "Terraform"
    ImportedBy  = "Gleb"
  }
}